TZ=Asia/Shanghai

# 现场与开发分离：复制本文件为 .env.docker 再改；上线包请记录同一提交下的 web/server/compose/nginx/init SQL 版本号
WEB_PORT=80
SERVER_PORT=8080
POSTGRES_PORT=5432

POSTGRES_DB=coal_platform
POSTGRES_USER=coal_user
POSTGRES_PASSWORD=change_me

SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin123

# 为 true 时 /api/** 需 HTTP Basic；与前端登录后 sessionStorage 的 Basic 一致（admin/admin123 或 viewer/viewer123）
PLATFORM_SECURITY_SECURE_API=false

# 现场默认 validate；表结构由 Flyway(db/migration) + init-core-tables.sql 初始化
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# 可选：启用 prod 配置档时需保证 application-prod.yml 中数据源等与现场一致
# SPRING_PROFILES_ACTIVE=prod

PLATFORM_IOT_PROVIDER=mock
PLATFORM_IOT_FALLBACK_TO_MOCK=true

PLATFORM_IOT_KEPSERVER_ENABLED=false
PLATFORM_IOT_KEPSERVER_ENDPOINT=opc.tcp://host.docker.internal:49320
PLATFORM_IOT_KEPSERVER_USERNAME=
PLATFORM_IOT_KEPSERVER_PASSWORD=
PLATFORM_IOT_KEPSERVER_SOURCE_TYPE=KEPSERVER
PLATFORM_IOT_KEPSERVER_CHANNEL_PREFIX=Channel1
PLATFORM_IOT_KEPSERVER_TIMEOUT_MS=3000

SMART_DENSITY_ENABLED=false
SMART_DENSITY_BASE_URL=http://host.docker.internal:6789
SMART_DENSITY_TIMEOUT_MS=3000
SMART_DENSITY_PORT=6789
SMART_DENSITY_RHO_SOURCE=param
SMART_DENSITY_DEFAULT_3207=1.43
SMART_DENSITY_DEFAULT_3208=1.47
SMART_DENSITY_DEFAULT_316=1.38
SMART_DENSITY_DB_HOST=smart-density-mysql
SMART_DENSITY_DB_PORT=3306
SMART_DENSITY_DB_PORT_EXPOSE=3306
SMART_DENSITY_DB_NAME=ai_data
SMART_DENSITY_DB_TABLE=opcdata
SMART_DENSITY_DB_USER=smart_density
SMART_DENSITY_DB_PASSWORD=smart_density_change_me
SMART_DENSITY_DB_ROOT_PASSWORD=root_change_me
SMART_DENSITY_DB_TIMEOUT_SEC=3

SMART_REAGENT_ENABLED=false
SMART_REAGENT_BASE_URL=http://host.docker.internal:6788
SMART_REAGENT_TIMEOUT_MS=3000
SMART_REAGENT_PORT=6788

# 模型回写 Node-RED/OPC 地址；如果现场暂时不回写，可保留默认值并忽略告警日志
MODEL_WRITEBACK_URL=http://host.docker.internal:1880/Post_mikong
