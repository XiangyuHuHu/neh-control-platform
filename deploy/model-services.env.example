# 智能密控与智能加药模型服务配置示例

SMART_DENSITY_ENABLED=true
SMART_DENSITY_BASE_URL=http://127.0.0.1:6789
SMART_DENSITY_TIMEOUT_MS=3000

SMART_REAGENT_ENABLED=true
SMART_REAGENT_BASE_URL=http://127.0.0.1:6788
SMART_REAGENT_TIMEOUT_MS=3000

# 如果 Docker 中的 server 访问宿主机模型服务，建议改成：
# SMART_DENSITY_BASE_URL=http://host.docker.internal:6789
# SMART_REAGENT_BASE_URL=http://host.docker.internal:6788
